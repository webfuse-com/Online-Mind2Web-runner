# Dataset (via Hugging Face)
HF_DATASET=osunlp/Online-Mind2Web
HF_SPLIT=train
HF_TOKEN=hf_abcdef123       # Hugging Face access token 
MAX_TASKS=0                 # 0 = all 300 tasks; ~5 for a smoke run

# Judge (evaluator) (via Online-Mind2Web submodule)
SUBMODULE_DIR=              # default: third_party/Online-Mind2Web
JUDGE_MODEL=gpt-4o          # authors recommend o4-mini; see README caveat
JUDGE_API_KEY=sk-abcdef123  # LLM provider API key (upstream: OpenAI)
SCORE_THRESHOLD=3           # 3 is ~85% human-agreement

# Target web agent
# Runner POSTs JSON { task_id, task, website, start_url, reference_length }.
# Agent must reply with an `online-mind2web-v2` result object:
#   { schema_version, task, task_id, agent_final_answer, reference_length, action_history: [ { step, screenshot, url, action, action_status, thought }, ... ] }
#   `screenshot` may be a URL, data-URI, local path, or raw Base64.
AGENT_URL=http://localhost:8000/agent
AGENT_API_KEY=              # default: sent as Bearer token
AGENT_TIMEOUT=900           # max seconds per task

# Runner
NUM_WORKERS=8               # agent calls collected concurrently
EVAL_WORKERS=0              # upstream --num_worker; 0 = NUM_WORKERS
TRAJECTORIES_DIR=           # default: ./trajectories (submission packages)
OUTPUT_PATH=                # default: ./eval_result (upstream JSONL results)