# Dataset (via Hugging Face)
HUGGINGFACE_DATASET=osunlp/Online-Mind2Web
HUGGINGFACE_SPLIT=test
HUGGINGFACE_TOKEN=hf_abcdef123  # Hugging Face access token 
MAX_TASKS=0                     # 0 = all 300 tasks; ~5 for a smoke run

# Judge (evaluator) (via Online-Mind2Web submodule)
SUBMODULE_DIR=                  # default: third_party/Online-Mind2Web
JUDGE_LLM=gpt-4o                # Authors recommend o4-mini
JUDGE_LLM_API_KEY=sk-abcdef123  # OpenAI API key (judge models)
SCORE_THRESHOLD=3               # 3 is ~85% human-agreement

# Runner
NUM_WORKERS=8                   # agent calls collected concurrently
EVAL_WORKERS=0                  # upstream --num_worker; 0 = NUM_WORKERS
TRAJECTORIES_DIR=               # default: ./trajectories (submission packages)
OUTPUT_PATH=                    # default: ./eval_result (upstream JSONL results)